# =============================================================
#  Red Horizon Cybersecurity — Deployment Config
#  Copy this file as .env alongside the install scripts.
#  Fill in values before running any installer.
#  ONE .env per client deployment.
# =============================================================

# ── Manager (RH-Wazuh VM) ────────────────────────────────────
HOSTNAME_NEW=RH-Wazuh
WAZUH_MANAGER_IP=192.168.112.10     # Static IP of Wazuh VM on host-only network
MGMT_IF=ens33                       # NAT interface (internet access)
AGENT_IF=ens37                      # Host-only interface (agent comms)
INDEXER_HEAP=4g                     # 50% of total RAM — adjust if RAM changes

# ── Enrollment (shared between manager + sensor) ─────────────
ENROLLMENT_PASSWORD=RedHorizon@Secure2025!   # Change per client

# ── Sensor (RH-Pulsar VM) ────────────────────────────────────
AGENT_NAME=RH-Pulsar-01             # Unique per sensor, per client
CLIENT_NAME=RedHorizon-Lab          # Used for agent grouping in dashboard
CAPTURE_IF=ens37                    # Promiscuous / mirror interface
# MGMT_IF already defined above

# ── Gmail SMTP Alerting ───────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-analyst@gmail.com    # Gmail account used to SEND alerts
SMTP_PASS=xxxx-xxxx-xxxx-xxxx       # Gmail App Password (not your login password)
                                    # Generate at: myaccount.google.com/apppasswords
ALERT_RECIPIENT=soc@redhorizon.ph   # Analyst inbox to RECEIVE alerts
ALERT_LEVEL=10                      # Minimum Wazuh rule level to trigger email
